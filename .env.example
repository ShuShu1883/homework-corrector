# Runtime mode. LLM_MODE=mock can be used for classroom demos after Tencent OCR is configured.
OCR_MODE=aliyun
LLM_MODE=api

# Thread pool size for background correction tasks.
MAX_WORKERS=3

# Runtime files. Leave APP_RUNTIME_DIR empty to use the project directory.
APP_RUNTIME_DIR=
CLEANUP_MAX_AGE_HOURS=24
CLEANUP_MAX_FILES_PER_DIR=120
CLEANUP_INTERVAL_SECONDS=600

# Legacy Aliyun OCR adapter.
# The first version supports a configurable Aliyun-compatible HTTP endpoint.
# Use APPCODE for Alibaba Cloud Marketplace style APIs, or API_KEY for bearer-key APIs.
ALIYUN_OCR_ENDPOINT=
ALIYUN_OCR_APPCODE=
ALIYUN_OCR_API_KEY=

# Tencent Cloud QuestionSplitOCR credentials.
# Used by the main correction flow and the paper-cut page.
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_OCR_REGION=ap-guangzhou
TENCENT_OCR_MAX_SIDE=1800
TENCENT_OCR_JPEG_QUALITY=86

# OpenAI-compatible LLM API.
# Works with OpenAI-compatible providers by changing LLM_BASE_URL and LLM_MODEL.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
