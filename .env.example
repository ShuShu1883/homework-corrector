# Runtime mode. LLM_MODE=mock can be used for classroom demos after Tencent OCR is configured.
LLM_MODE=api

# Thread pool size for background correction tasks.
MAX_WORKERS=3

# Runtime files. Leave APP_RUNTIME_DIR empty to use the project directory.
APP_RUNTIME_DIR=
CLEANUP_MAX_AGE_HOURS=24
CLEANUP_INTERVAL_SECONDS=600

# Storage backend. Use DB_BACKEND=mysql on Streamlit Cloud after setting MYSQL_PASSWORD.
DB_BACKEND=json
MYSQL_HOST=mysql6.sqlpub.com
MYSQL_PORT=3311
MYSQL_DATABASE=py_home_corrector
MYSQL_USER=tangffy
MYSQL_PASSWORD=
MYSQL_SSL=false

# Tencent Cloud QuestionSplitOCR credentials.
# Used by the main correction flow and the paper-cut page.
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_OCR_REGION=ap-guangzhou
TENCENT_OCR_MAX_SIDE=1800
TENCENT_OCR_JPEG_QUALITY=86

# DeepSeek OpenAI-compatible LLM API.
# deepseek-v4-pro is recommended for grading stability.
# Put real keys only in local .env or Streamlit Secrets. Do not commit real keys.
LLM_API_KEY=
DEEPSEEK_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro
LLM_MAX_TOKENS=4096
DEEPSEEK_THINKING=disabled
LLM_CONSISTENCY_RETRIES=2
