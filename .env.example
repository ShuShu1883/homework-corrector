# Runtime mode. Use mock for classroom demos without real API keys.
OCR_MODE=aliyun
LLM_MODE=api

# Thread pool size for background correction tasks.
MAX_WORKERS=3

# Aliyun OCR adapter.
# The first version supports a configurable Aliyun-compatible HTTP endpoint.
# Use APPCODE for Alibaba Cloud Marketplace style APIs, or API_KEY for bearer-key APIs.
ALIYUN_OCR_ENDPOINT=
ALIYUN_OCR_APPCODE=
ALIYUN_OCR_API_KEY=

# Aliyun official OCR API credentials for RecognizeEduPaperCut.
# Do not commit real keys. Put them in local .env or Streamlit Secrets.
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_PAPER_CUT_ENDPOINT=ocr-api.cn-hangzhou.aliyuncs.com

# OpenAI-compatible LLM API.
# Works with OpenAI-compatible providers by changing LLM_BASE_URL and LLM_MODEL.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
